{
    "rewrites": [
        {
            "source": "/(all-image-converters|about-us|contact-us|privacy-policy|terms-of-service|blog|blog/[^/]+|blog\\.html|image-resizer|image-compressor|crop-image|bg-remover|image-enhancer|image-to-art|passport-size-photo|image-converter|3d-text-to-stl-generator|svg-to-stl|aadhaar-card-print-setting-a4|ssc-photo-date-adder|pan-card-photo|pdf-to-jpg|pdf-to-png|pdf-to-gif|jpg-to-pdf|png-to-pdf|webp-to-pdf|heic-to-pdf|gif-to-pdf|svg-to-pdf|pdf-crop|merge-pdf|avif-to-jpg|avif-to-png|avif-to-webp|heic-to-jpg|heic-to-png|heic-to-webp|heic-to-gif|webp-to-jpg|webp-to-png|webp-to-ico|webp-to-bmp|webp-to-tiff|webp-to-gif|png-to-jpg|png-to-webp|png-to-ico|png-to-svg|png-to-bmp|png-to-gif|png-to-tiff|png-to-avif|jpg-to-png|jpg-to-webp|jpg-to-ico|jpg-to-svg|jpg-to-bmp|jpg-to-gif|jpg-to-tiff|jpg-to-avif|bmp-to-jpg|bmp-to-png|bmp-to-webp|bmp-to-gif|gif-to-jpg|gif-to-png|gif-to-webp|gif-to-ico|gif-to-bmp|ico-to-png|ico-to-jpg|ico-to-gif|svg-to-png|svg-to-jpg|tiff-to-jpg|tiff-to-png|tiff-to-webp|raw-to-jpg|cr2-to-jpg|video-compressor|video-converter|video-to-audio|video-trimmer|video-merger|pdf-to-excel|html-to-pdf|remove-pdf-watermark|pdf-password-remover|collage-maker|favicon-generator|image-metadata-viewer|color-palette-generator|worksheet-converter|text-to-handwriting|html-table-generator|qr-code-generator|combine-images-side-by-side|add-watermark-to-image|merge-images-vertically|blend-two-photos|rotate-image-custom-angle|flip-image-horizontally|polaroid-photo-effect|add-drop-shadow|wet-floor-reflection|zoomed-inset-image|instagram-safe-zones|meme-generator|gif-maker|lego-art-generator|warhol-poster-effect|emoji-mosaic|jigsaw-puzzle-maker|face-morph|sticker-add-virtual|ai-denoiser|ai-colorizer)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/favicon.svg",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                }
            ]
        },
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400, stale-while-revalidate=3600"
                }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}